{
  "name": "home-dashboard",
  "version": "0.0.1",
  "private": true,
  "description": "Open-source wall-mounted home dashboard — unifies Home Assistant, media, calendars, energy, and network status on a touchscreen kiosk.",
  "license": "MIT",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ha:explore": "node packages/integrations/home-assistant/scripts/explore.mjs",
    "onboard": "node packages/integrations/home-assistant/scripts/onboard.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.0",
    "turbo": "^2.3.0"
  }
}
